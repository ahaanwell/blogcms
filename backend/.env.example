# ── SERVER ────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── DATABASE ──────────────────────────────────────────────
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/blog_admin

# ── JWT (admin login) ─────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this

# ── CLOUDINARY ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── ADMIN PANEL ORIGIN ────────────────────────────────────
# Only your admin panel URL — everything else is managed in the DB
ADMIN_ORIGINS=http://localhost:3000

# ── DEV ONLY: skip API key check ─────────────────────────
# Set to true to bypass x-api-key check during local development
DEV_SKIP_API_KEY=true
